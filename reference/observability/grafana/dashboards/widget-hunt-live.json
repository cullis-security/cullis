      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service=~\"alice-.+|bob-.+\"} |~ \"tool\\\\.|inbox\\\\.recv|kick-off|max_hops|FAILED\"",
          "queryType": "range",
          "refId": "A"
