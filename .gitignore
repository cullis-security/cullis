__pycache__/
*.py[cod]
.venv/

# Database
*.db

# Env
.env

# Test cache
.pytest_cache/

# E2E test fixtures (broker CA copy, writable for container appuser)
tests/e2e/.fixtures/

# Demo runtime state — broker CA fixture, agent credentials, checker daemon
# pid + log. The actual demo source (scripts/demo/*.py, README, compose) is
# tracked; only the generated state is ignored.
scripts/demo/.fixtures/
scripts/demo/.state.json
scripts/demo/.checker.pid
scripts/demo/.checker.log

# Accidental copy of the repo created by `git clone` inside the working
# tree (e.g. when copy-pasting the README quickstart). Anchored to the
# repo root with a leading `/` so it does NOT match `deploy/helm/cullis/`
# or any other legitimate `cullis/` subdirectory deeper in the tree.
/cullis/

# Local-only: notes, drafts, root demo dir, CLI tools.
# `/demo/` is anchored to the repo root so it does NOT match `scripts/demo/`.
imp/
/demo/
drafts/
admin.py
bootstrap.py
join.py
join_agent.py
policy.py
revoke.py
generate_demo_certs.py
# generate_certs.py is INTENTIONALLY tracked — it is a runtime dependency
# of both deploy_broker.sh and deploy_demo.sh (they invoke it on a fresh
# clone to bootstrap the broker CA).
agents/*.env
agents/buyer.py
agents/manufacturer.py
agents/client.py
