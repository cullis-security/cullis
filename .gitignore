# Certificati — non committare chiavi private
certs/

# Python
__pycache__/
*.py[cod]
.venv/

# Database
*.db

# Env
.env

# Test cache
.pytest_cache/

# E2E test fixtures (broker CA copy, writable for container appuser)
tests/e2e/.fixtures/

# Accidental copy of the repo created by `git clone` inside the working
# tree (e.g. when copy-pasting the README quickstart). Anchored to the
# repo root with a leading `/` so it does NOT match `deploy/helm/cullis/`
# or any other legitimate `cullis/` subdirectory deeper in the tree.
/cullis/

# Local-only: notes, drafts, root demo dir.
imp/
/demo/
drafts/
# generate_certs.py is INTENTIONALLY tracked, runtime dependency
# of deploy_broker.sh (invoked on a fresh clone to bootstrap the broker CA).
CLAUDE.md
.claude/
enterprise-lab/
org-node/
backups/
vault/vault-keys.json

# MCP Proxy local data
mcp_proxy.db
mcp_proxy.db.*.lock
proxy.env
proxy-*.env
.keys/
postgresql+asyncpg:/

# ADR-030 — Mastio bundle bind-mount targets (operator state, not source)
packaging/mastio-bundle/data/
packaging/mastio-bundle/nginx-certs/
packaging/mastio-bundle/backups/

# Nginx proxy (TLS private keys, per-VM configs)
nginx-proxy/

# Manual shake-out session notes (local, not published)
shake-out-notes.md

# Nix dev shell — personal environment file, not part of the project.
# Contributors on macOS/Ubuntu/Windows use their own setup; on Nix you
# can symlink or copy this from your personal dotfiles.
shell.nix

# Frontend build artifacts (generated by Tailwind CLI — see README)
node_modules/
package-lock.json
!site/package-lock.json
!frontend/cullis-chat/package-lock.json
app/static/css/tailwind.css
mcp_proxy/dashboard/static/css/tailwind.css

# Staged files for the standalone `cullis-connector` PyPI build. They
# are copied in from the monorepo root by packaging/pypi/build.sh and
# are never authored in-place — the source of truth lives at repo root.
packaging/pypi/cullis_connector/
packaging/pypi/README_PKG.md
packaging/pypi/LICENSE
packaging/pypi/LICENSE-APACHE-2.0
packaging/pypi/NOTICE
packaging/pypi/CHANGELOG.md

# Same staging pattern for the standalone `cullis-sdk` PyPI build.
packaging/pypi-sdk/cullis_sdk/
packaging/pypi-sdk/README_PKG.md
packaging/pypi-sdk/LICENSE
packaging/pypi-sdk/LICENSE-APACHE-2.0
packaging/pypi-sdk/NOTICE
packaging/pypi-sdk/CHANGELOG.md

# Cullis Chat SPA static — built artefact, not source. Copied here by
# scripts/build-spa.sh before packaging the Connector wheel (ADR-019
# Phase 8c). Reproducible from frontend/cullis-chat/.
cullis_connector/static/cullis-chat/

# Python build outputs
dist/
build/
*.egg-info/
/sandbox/.env

# Frontdesk Connector identity material (per-deployment, never committed)
packaging/frontdesk-bundle/connector_data/
packaging/frontdesk-bundle/frontdesk.env
# #655 / ADR-024 — self-signed TLS material minted at deploy time by
# mint-tls-cert.sh. Contains the local CA private key, never commit.
# Operators rotate by deleting this dir and re-running ./deploy.sh.
packaging/frontdesk-bundle/tls/

# Local NixOS test artifacts (rooted to repo root only)
/.nixos-test-history
/cliente.qcow2
/result

# Per-scenario state with private keys + org-secrets. Generated by
# bootstrap scripts on demand, MUST never be committed.
/state/
.gstack/

# k6 stress test artefacts (transient summary dumps next to the scripts).
scripts/stress/summary*.json
scripts/stress/soak-summary*.json
scripts/stress/stress_agents.json
scripts/stress/intra-org-results*.json
scripts/stress/intra-org-results.ndjson
scripts/stress/intra-org-summary*.json
scripts/stress/*.log
