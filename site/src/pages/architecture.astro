---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Architecture — Mastio inside your org, Court when you federate | Cullis"
  description="Mastio is the control point each organization installs for its own AI agents. Court is the optional Day-2 layer that federates Mastios across organizations by routing sealed envelopes it cannot open."
>

  <!-- HEAD -->
  <section class="page-head">
    <div class="container">
      <div class="head-grid">
        <aside class="head-marginalia reveal">
          <div class="scribble">CLLS-0002</div>
          <div class="folio">§ <em>Architecture</em></div>
        </aside>
        <div>
          <div class="eyebrow reveal" data-delay="1">
            <span class="eyebrow-number">01</span>
            Of the architecture
          </div>
          <h1 class="reveal" data-delay="2">
            How <em>Mastio</em> works,<br />and how <em>Court</em> federates.
          </h1>
          <p class="lead reveal" data-delay="3">
            Mastio is what every organization installs first: identity,
            policy, audit, MCP and LLM gateway for its own AI agents.
            Court is the optional Day-2 layer that connects two or more
            Mastios across companies, routing sealed envelopes it cannot
            open. Same binary, two adoption timelines.
          </p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- DAY-1 STANDALONE TOPOLOGY -->
  <section class="day1-section">
    <div class="container">
      <div class="eyebrow reveal">
        <span class="eyebrow-number">02</span>
        Day-1 · Mastio works alone
      </div>
      <h2 class="reveal" data-delay="1">Bring your <em>existing stack</em>.</h2>
      <p class="day1-lead reveal" data-delay="2">
        Mastio is the org control point. Day-1 it runs alone — one
        container, sensible defaults, no external dependency. Day-N you
        attach what you already have: your PKI, your OPA, your IDP, your
        KMS, your observability. One Docker image, every dependency
        optional.
      </p>

      <figure class="day1-figure reveal" data-delay="3">
        <div class="day1-grid">

          <!-- NORTH — identities -->
          <div class="day1-cluster north">
            <div class="cluster-label">Identities</div>
            <div class="cluster-row">
              <div class="spoke solid">
                <div class="spoke-name">Connector</div>
                <div class="spoke-sub">IDE / laptop · MCP</div>
              </div>
              <div class="spoke solid">
                <div class="spoke-name">Frontdesk</div>
                <div class="spoke-sub">multi-user chat · shared mode</div>
              </div>
              <div class="spoke dashed">
                <div class="spoke-name">BYOCA</div>
                <div class="spoke-sub">programmatic agents · opt-in</div>
              </div>
            </div>
          </div>

          <!-- WEST — trust + obs -->
          <div class="day1-cluster west">
            <div class="cluster-label">Trust + Observability</div>
            <div class="cluster-col">
              <div class="spoke dashed">
                <div class="spoke-name">External PDP</div>
                <div class="spoke-sub">OPA · webhook · opt-in</div>
              </div>
              <div class="spoke dashed">
                <div class="spoke-name">OIDC</div>
                <div class="spoke-sub">oauth2-proxy · IDP · opt-in</div>
              </div>
              <div class="spoke solid">
                <div class="spoke-name">Prometheus</div>
                <div class="spoke-sub">metrics scrape</div>
              </div>
            </div>
          </div>

          <!-- HUB — Mastio -->
          <div class="day1-hub">
            <div class="hub-rule"></div>
            <div class="hub-name">CULLIS MASTIO</div>
            <ul class="hub-features">
              <li>Org CA + 3-tier PKI</li>
              <li>Policy engine</li>
              <li>Audit chain (SHA-256)</li>
              <li>AI gateway (LiteLLM)</li>
              <li>MCP reverse-proxy</li>
              <li>Dashboard <code>:9443</code></li>
            </ul>
            <div class="hub-rule"></div>
          </div>

          <!-- EAST — AI + tools -->
          <div class="day1-cluster east">
            <div class="cluster-label">AI + tools</div>
            <div class="cluster-col">
              <div class="spoke solid">
                <div class="spoke-name">LLM providers</div>
                <div class="spoke-sub">Anthropic · OpenAI · Gemini · Ollama (via LiteLLM)</div>
              </div>
              <div class="spoke dashed">
                <div class="spoke-name">Alt AI gateway</div>
                <div class="spoke-sub">sidecar pattern · opt-in</div>
              </div>
              <div class="spoke solid">
                <div class="spoke-name">MCP tools</div>
                <div class="spoke-sub">filesystem · GitHub · Slack · custom</div>
              </div>
            </div>
          </div>

          <!-- SOUTH — state + secrets -->
          <div class="day1-cluster south">
            <div class="cluster-label">State + Secrets</div>
            <div class="cluster-row">
              <div class="spoke solid">
                <div class="spoke-name">Database</div>
                <div class="spoke-sub">SQLite default · Postgres prod</div>
              </div>
              <div class="spoke dashed">
                <div class="spoke-name">Redis</div>
                <div class="spoke-sub">DPoP JTI · rate limit · multi-worker</div>
              </div>
              <div class="spoke solid">
                <div class="spoke-name">KMS</div>
                <div class="spoke-sub">filesystem default · Vault prod</div>
              </div>
            </div>
          </div>

        </div>

        <figcaption>
          Fig. <em>I</em> — Day-1 Mastio standalone. <strong>Solid</strong>
          borders ship by default or are production-ready;
          <strong>dashed</strong> borders are opt-in. Cross-org federation
          layer (Court, RFC 3161 TSA, OTEL traces) appears in
          <a href="#federation">Fig. II</a>.
        </figcaption>
      </figure>

      <div class="day1-legend reveal" data-delay="4">
        <span class="legend-item">
          <span class="legend-swatch solid"></span>
          Default or production-ready
        </span>
        <span class="legend-item">
          <span class="legend-swatch dashed"></span>
          Opt-in / preview
        </span>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- LIVE NETWORK STAGE -->
  <section class="net-section" id="federation">
    <div class="container">
      <div class="eyebrow reveal">
        <span class="eyebrow-number">03</span>
        Federation in action (Day-2)
      </div>
      <h2 class="reveal" data-delay="1">When two Mastios <em>talk</em>.</h2>
      <p class="net-lead reveal" data-delay="2">
        Two organizations, three agents, live traffic. The federation
        layer activates when you need agent-to-agent across companies.
        Inside one company, this stage is not in the picture: Mastio
        handles intra-org traffic locally, Court is not contacted.
      </p>

      <figure class="reveal" data-delay="3">
        <div class="network-stage">
          <div class="stage-header">
            <div class="stage-title">↓ <strong>Federation topology</strong> · attach-CA × 2 · SPIFFE trust domains</div>
            <div class="stage-counter">
              <span>● <span id="msg-count">147</span> messages</span>
              <span>● <span id="audit-count">147</span> audit</span>
              <span>● <span id="block-count">3</span> blocked</span>
            </div>
          </div>

          <div class="network-grid" id="arch-grid">
            <!-- ORG A: ACME -->
            <div class="org-perimeter">
              <div class="org-perimeter-label">
                <span class="name">ACME BANK</span>
                <span class="trust">spiffe://acme.demo/</span>
              </div>
              <div class="perimeter-grid">
                <div class="agents-stack">
                  <div class="agent-card" id="ag-buyer" data-org="acme" data-name="buyer-agent">
                    <div class="agent-icon">B</div>
                    <div class="agent-info">
                      <div class="agent-name">buyer-agent</div>
                      <div class="agent-spiffe">spiffe://acme.demo/buyer-agent</div>
                    </div>
                    <div class="agent-status"></div>
                  </div>
                  <div class="agent-card" id="ag-auditor" data-org="acme" data-name="auditor-agent">
                    <div class="agent-icon">A</div>
                    <div class="agent-info">
                      <div class="agent-name">auditor-agent</div>
                      <div class="agent-spiffe">spiffe://acme.demo/auditor-agent</div>
                    </div>
                    <div class="agent-status"></div>
                  </div>
                </div>
                <div class="proxy-col">
                  <div class="proxy-box" id="proxy-acme">
                    <div class="proxy-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="#00e5c7" stroke-width="1.6">
                        <rect x="3" y="6" width="18" height="12" rx="1"/>
                        <path d="M3 10h18M7 14h2M11 14h2M15 14h2"/>
                      </svg>
                    </div>
                    <div class="proxy-info">
                      <div class="proxy-name">Cullis Mastio</div>
                      <div class="proxy-stats"><span>local audit <strong>142</strong></span><span>policies <strong>7</strong></span></div>
                    </div>
                    <div class="proxy-uplink">
                      <span class="pulse-dot moss"></span>
                      uplinked
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- COURT (center) -->
            <div class="broker-panel">
              <div class="broker-label">cross-org<br>federation</div>
              <div class="broker-name">CULLIS<br>COURT</div>
              <div class="broker-stats">
                <div class="broker-stat"><span>Trust domains</span><strong>2</strong></div>
                <div class="broker-stat"><span>Attach-CA</span><strong>2 / 2</strong></div>
                <div class="broker-stat"><span>Sessions</span><strong>4</strong></div>
                <div class="broker-stat"><span>Dual-write</span><strong class="ok">OK</strong></div>
              </div>
            </div>

            <!-- ORG B: GLOBEX -->
            <div class="org-perimeter">
              <div class="org-perimeter-label">
                <span class="name">GLOBEX KYC</span>
                <span class="trust">spiffe://globex.demo/</span>
              </div>
              <div class="perimeter-grid mirror">
                <div class="proxy-col">
                  <div class="proxy-box" id="proxy-globex">
                    <div class="proxy-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="#00e5c7" stroke-width="1.6">
                        <rect x="3" y="6" width="18" height="12" rx="1"/>
                        <path d="M3 10h18M7 14h2M11 14h2M15 14h2"/>
                      </svg>
                    </div>
                    <div class="proxy-info">
                      <div class="proxy-name">Cullis Mastio</div>
                      <div class="proxy-stats"><span>local audit <strong>138</strong></span><span>policies <strong>5</strong></span></div>
                    </div>
                    <div class="proxy-uplink">
                      <span class="pulse-dot moss"></span>
                      uplinked
                    </div>
                  </div>
                </div>
                <div class="agents-stack">
                  <div class="agent-card" id="ag-kyc" data-org="globex" data-name="kyc-agent">
                    <div class="agent-icon">K</div>
                    <div class="agent-info">
                      <div class="agent-name">kyc-agent</div>
                      <div class="agent-spiffe">spiffe://globex.demo/kyc-agent</div>
                    </div>
                    <div class="agent-status"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- SVG flow overlay -->
            <svg class="network-svg" id="arch-net-svg" preserveAspectRatio="none">
              <path id="arch-trace-cross" class="flow-line" d=""></path>
              <path id="arch-trace-intra" class="flow-line intra" d=""></path>
              <path id="arch-pulse-cross-fwd" class="flow-pulse" d=""></path>
              <path id="arch-pulse-cross-rev" class="flow-pulse" d=""></path>
              <path id="arch-pulse-intra" class="flow-pulse intra-pulse" d=""></path>
            </svg>
          </div>
        </div>
        <figcaption>
          Fig. <em>I</em> — Live view of the three-tier fabric. Acme Bank and
          Globex KYC speak across <em>trust domains</em>; intra-org traffic stays
          inside the local <em>Mastio</em>; only cross-org hops pass through the
          <em>Court</em>.
        </figcaption>
      </figure>
    </div>
  </section>

  <hr class="divider" />

  <!-- TWO MODES -->
  <section class="modes">
    <div class="container">
      <div class="eyebrow reveal">
        <span class="eyebrow-number">04</span>
        Two routing modes
      </div>
      <h2 class="reveal" data-delay="1">One binary, <em>two paths</em>.</h2>

      <div class="mode-grid">
        <article class="mode-card reveal" data-delay="2">
          <div class="mode-head">
            <span class="mode-num">I.</span>
            <h3>Intra-organization</h3>
          </div>
          <p class="mode-tag"><em>agent to agent inside the same company. Day-1, always on.</em></p>
          <ul class="mode-list">
            <li><span class="key">Path</span><span>Connector → Mastio → Connector</span></li>
            <li><span class="key">Payload</span><span>Signed (<code>ECDSA P-256</code>), not encrypted</span></li>
            <li><span class="key">Policy</span><span>Evaluated once, locally</span></li>
            <li><span class="key">Audit</span><span>Hash-chain, local, never leaves the org</span></li>
            <li><span class="key">Court role</span><span>Not contacted</span></li>
          </ul>
        </article>

        <article class="mode-card cross reveal" data-delay="3">
          <div class="mode-head">
            <span class="mode-num">II.</span>
            <h3>Cross-organization</h3>
            <span class="mode-day2">Day-2 · opt-in</span>
          </div>
          <p class="mode-tag"><em>agent to agent across different companies. Activated when you federate.</em></p>
          <ul class="mode-list">
            <li><span class="key">Path</span><span>Connector → Mastio A → Court → Mastio B → Connector</span></li>
            <li><span class="key">Payload</span><span>End-to-end encrypted (<code>ECDH P-256</code>, <code>AES-256-GCM</code>)</span></li>
            <li><span class="key">Policy</span><span>Both orgs evaluate; both must allow</span></li>
            <li><span class="key">Audit</span><span>Both Mastios locally; Court logs routing only</span></li>
            <li><span class="key">Court role</span><span>Routes sealed envelope, cannot decrypt</span></li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ZK -->
  <section class="zk">
    <div class="container narrow">
      <div class="zk-mark reveal">◈</div>
      <blockquote class="reveal" data-delay="1">
        The Court sees <em>who</em> spoke to <em>whom</em>,<br/>
        and <em>when</em>.<br/>
        It never sees <em>what</em> was said.
      </blockquote>
      <p class="zk-note reveal" data-delay="2">
        End-to-end encryption is between the two Mastios. The Court routes
        ciphertext by design: even if an adversary compromises the entire
        network operator, cross-organization messages remain confidential.
      </p>
    </div>
  </section>

  <hr class="divider" />

  <!-- THREAT MODEL -->
  <section class="prose-section">
    <div class="container">
      <div class="eyebrow reveal">
        <span class="eyebrow-number">05</span>
        Threat model
      </div>
      <h2 class="reveal" data-delay="1">What we <em>assume</em>, and what we <em>defend</em>.</h2>

      <table class="ledger reveal" data-delay="2">
        <thead>
          <tr>
            <th style="width: 26%">Adversary</th>
            <th style="width: 37%">Capability assumed</th>
            <th style="width: 37%">Cullis defense</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Malicious agent inside the org</td>
            <td>Crafts arbitrary payloads with stolen bearer tokens.</td>
            <td>Per-agent x509 + DPoP binding — a stolen bearer is useless without the agent's EC private key.</td>
          </tr>
          <tr>
            <td>Compromised Mastio admin</td>
            <td>Rewrites local audit logs.</td>
            <td>Append-only SHA-256 hash-chain; cross-org events dual-anchored in Court and counterparty Mastio.</td>
          </tr>
          <tr>
            <td>Compromised Court operator</td>
            <td>Full root on the Court machine.</td>
            <td>Cross-org payload is sealed between Mastios; Court sees only metadata. Root on Court ≠ read on messages.</td>
          </tr>
          <tr>
            <td>Cross-org impostor</td>
            <td>Registers a look-alike agent in a partner org.</td>
            <td>SPIFFE SAN + federated CA trust: identities resolve to the correct org's CA; impostor cert fails chain validation.</td>
          </tr>
          <tr>
            <td>Policy drift</td>
            <td>Admin misconfigures policy.</td>
            <td>Default-deny. Both orgs must allow on cross-org. Policy changes themselves land in the audit chain.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <hr class="divider" />

  <!-- CLOSING -->
  <section class="closing">
    <div class="container narrow">
      <div class="closing-rule"></div>
      <div class="eyebrow">
        <span class="eyebrow-number">06</span>
        Continue
      </div>
      <h2>Use case, <em>deployment</em>, source.</h2>
      <p>
        Mastio scales from air-gapped standalone to cross-organization
        federation. Same binary, no redeploy, no re-enrollment. Pick
        the path that matches your compliance surface.
      </p>
      <div class="hero-actions">
        <a href="/insurance" class="btn btn-primary">Insurance use case</a>
        <a href="/deployment" class="btn btn-ghost">Deployment patterns</a>
        <a href="https://github.com/cullis-security/cullis" target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (() => {
    const FAKE_AGENTS = {
      'buyer-agent':   { org: 'acme',   el: 'ag-buyer' },
      'auditor-agent': { org: 'acme',   el: 'ag-auditor' },
      'kyc-agent':     { org: 'globex', el: 'ag-kyc' },
    };
    const SAMPLE = [
      { from: 'buyer-agent',   to: 'kyc-agent',    scope: 'cross' },
      { from: 'kyc-agent',     to: 'buyer-agent',  scope: 'cross' },
      { from: 'buyer-agent',   to: 'auditor-agent', scope: 'intra' },
      { from: 'auditor-agent', to: 'buyer-agent',   scope: 'intra' },
      { from: 'buyer-agent',   to: 'kyc-agent',    scope: 'cross' },
      { from: 'kyc-agent',     to: 'buyer-agent',  scope: 'cross' },
    ];
    const STATE = { msgCount: 147, auditCount: 147 };

    function centerOf(el, parent) {
      const r = el.getBoundingClientRect();
      const p = parent.getBoundingClientRect();
      return {
        x: r.left - p.left + r.width / 2,
        y: r.top - p.top + r.height / 2,
        right: r.right - p.left,
        left: r.left - p.left,
      };
    }

    function setupSvgPaths() {
      const grid = document.getElementById('arch-grid');
      const svg = document.getElementById('arch-net-svg');
      if (!grid || !svg) return;
      const rect = grid.getBoundingClientRect();
      svg.setAttribute('viewBox', '0 0 ' + rect.width + ' ' + rect.height);

      const pAcme = centerOf(document.getElementById('proxy-acme'), grid);
      const pGlob = centerOf(document.getElementById('proxy-globex'), grid);
      const broker = centerOf(document.querySelector('.broker-panel'), grid);
      const buyer = centerOf(document.getElementById('ag-buyer'), grid);
      const auditor = centerOf(document.getElementById('ag-auditor'), grid);
      const kyc = centerOf(document.getElementById('ag-kyc'), grid);

      const yLine = pAcme.y;
      const ax1 = buyer.right - 6;
      const ax2 = pAcme.x;
      const ax3 = broker.x;
      const ax4 = pGlob.x;
      const ax5 = kyc.left + 6;

      const crossPath =
        'M ' + ax1 + ' ' + buyer.y +
        ' C ' + (ax1 + 24) + ' ' + buyer.y + ', ' + (ax2 - 30) + ' ' + yLine + ', ' + ax2 + ' ' + yLine +
        ' L ' + ax3 + ' ' + yLine +
        ' L ' + ax4 + ' ' + yLine +
        ' C ' + (ax4 + 30) + ' ' + yLine + ', ' + (ax5 - 24) + ' ' + kyc.y + ', ' + ax5 + ' ' + kyc.y;

      const traceCross = document.getElementById('arch-trace-cross');
      const pulseFwd = document.getElementById('arch-pulse-cross-fwd');
      const pulseRev = document.getElementById('arch-pulse-cross-rev');
      if (traceCross) traceCross.setAttribute('d', crossPath);
      if (pulseFwd) pulseFwd.setAttribute('d', crossPath);
      if (pulseRev) pulseRev.setAttribute('d', crossPath);

      const ix1 = buyer.right - 6;
      const ix2 = pAcme.x;
      const ix3 = auditor.right - 6;
      const sweep = Math.max(80, pAcme.left - buyer.right);
      const intraAcmePath =
        'M ' + ix1 + ' ' + buyer.y +
        ' C ' + (ix1 + sweep * 0.55) + ' ' + buyer.y + ', ' + (ix2 - 35) + ' ' + pAcme.y + ', ' + ix2 + ' ' + pAcme.y +
        ' C ' + (ix2 - 35) + ' ' + pAcme.y + ', ' + (ix3 + sweep * 0.55) + ' ' + auditor.y + ', ' + ix3 + ' ' + auditor.y;

      const traceIntra = document.getElementById('arch-trace-intra');
      const pulseIntra = document.getElementById('arch-pulse-intra');
      if (traceIntra) traceIntra.setAttribute('d', intraAcmePath);
      if (pulseIntra) pulseIntra.setAttribute('d', intraAcmePath);
    }

    function pulseFlow(scope, direction) {
      let pathId;
      if (scope === 'cross') {
        pathId = direction === 'forward' ? 'arch-pulse-cross-fwd' : 'arch-pulse-cross-rev';
      } else {
        pathId = 'arch-pulse-intra';
      }
      const p = document.getElementById(pathId);
      if (!p || !p.getTotalLength) return;
      const len = p.getTotalLength();
      if (len < 10) return;
      if (p._raf) cancelAnimationFrame(p._raf);

      const dotLen = 22;
      p.style.strokeDasharray = dotLen + ' ' + (len + 100);
      p.classList.remove('active');
      p.classList.add('active');
      p.style.opacity = '1';
      p.style.transition = '';

      const duration = 2800;
      const start = direction === 'reverse' ? -len : 0;
      const end = direction === 'reverse' ? 0 : -len;
      const t0 = performance.now();

      function tick(now) {
        const elapsed = now - t0;
        const k = Math.min(1, elapsed / duration);
        p.style.strokeDashoffset = String(start + (end - start) * k);
        if (k < 1) {
          p._raf = requestAnimationFrame(tick);
        } else {
          p.style.transition = 'opacity 280ms ease';
          p.style.opacity = '0';
          setTimeout(() => {
            p.style.transition = '';
            p.classList.remove('active');
          }, 320);
          p._raf = null;
        }
      }
      p._raf = requestAnimationFrame(tick);
    }

    function flashAgent(agentName, scope) {
      const ag = FAKE_AGENTS[agentName];
      if (!ag) return;
      const el = document.getElementById(ag.el);
      if (!el) return;
      const cls = scope === 'cross' ? 'flash-cross' : 'flash-intra';
      el.classList.remove('flash-cross', 'flash-intra');
      void el.getBoundingClientRect();
      el.classList.add(cls);
      setTimeout(() => el.classList.remove(cls), 2400);
    }

    let trafficIdx = 0;
    function backgroundTick() {
      const p = SAMPLE[trafficIdx % SAMPLE.length];
      trafficIdx++;
      STATE.msgCount++;
      STATE.auditCount++;
      const mc = document.getElementById('msg-count');
      const ac = document.getElementById('audit-count');
      if (mc) mc.textContent = STATE.msgCount;
      if (ac) ac.textContent = STATE.auditCount;

      const fromOrg = FAKE_AGENTS[p.from] && FAKE_AGENTS[p.from].org;
      const direction = fromOrg === 'acme' ? 'forward' : 'reverse';
      pulseFlow(p.scope, direction);
      flashAgent(p.from, p.scope);
      flashAgent(p.to, p.scope);
    }

    window.addEventListener('resize', () => setTimeout(setupSvgPaths, 30));
    window.addEventListener('load', () => setTimeout(setupSvgPaths, 80));
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(() => setTimeout(setupSvgPaths, 30));
    }
    const gridEl = document.getElementById('arch-grid');
    if (gridEl && 'ResizeObserver' in window) {
      new ResizeObserver(() => setupSvgPaths()).observe(gridEl);
    }
    setTimeout(setupSvgPaths, 0);
    setTimeout(backgroundTick, 2200);
    setInterval(backgroundTick, 5500);
  })();
</script>

