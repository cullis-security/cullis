---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  author: string;
  readingTime?: number;
}

const { title, description, date, author, readingTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — Cullis`} description={description}>
  <article class="post">
    <!-- Hero -->
    <header class="post-hero">
      <div class="container narrow">
        <div class="post-meta reveal">
          <span class="pm-date">{formattedDate}</span>
          <span class="pm-sep">·</span>
          <span class="pm-author">{author}</span>
          {readingTime && (
            <>
              <span class="pm-sep">·</span>
              <span class="pm-read">{readingTime} min read</span>
            </>
          )}
        </div>

        <h1 class="post-title reveal" data-delay="1">{title}</h1>

        {description && <p class="post-desc reveal" data-delay="2">{description}</p>}
      </div>
    </header>

    <!-- Body -->
    <div class="container narrow">
      <div class="post-body prose dropcap-first">
        <slot />
      </div>

      <footer class="post-footer">
        <div class="pf-rule"></div>
        <div class="pf-meta">
          <div>
            <div class="pf-label">Written by</div>
            <div class="pf-value">{author}</div>
          </div>
          <div>
            <div class="pf-label">Published</div>
            <div class="pf-value">{formattedDate}</div>
          </div>
        </div>
        <a href="/blog" class="back-link">← All posts</a>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .post { padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: 4rem; }

  /* Hero */
  .post-hero {
    padding-bottom: 3rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    flex-wrap: wrap;
  }

  .pm-date { color: var(--accent-cyan); }
  .pm-sep { opacity: 0.5; }
  .pm-author, .pm-read { color: var(--text-secondary); }

  .post-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }

  .post-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: 1.4;
    color: var(--text-secondary);
    margin: 0;
    max-width: 62ch;
  }

  /* Body */
  .post-body {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.75;
  }

  .post-body :global(> p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-style: italic;
    float: left;
    font-size: 5.2em;
    line-height: 0.88;
    padding-right: 0.12em;
    padding-top: 0.04em;
    color: var(--accent-cyan);
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 3rem 0 1.25rem;
    letter-spacing: -0.015em;
    line-height: 1.15;
  }

  .post-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
    line-height: 1.25;
  }

  .post-body :global(p) {
    margin-bottom: 1.3em;
    max-width: 68ch;
  }

  .post-body :global(em) { color: var(--accent-cyan); font-style: italic; }
  .post-body :global(strong) { color: var(--text-primary); font-weight: 500; }

  .post-body :global(a) {
    color: var(--accent-cyan);
    border-bottom: 1px solid var(--accent-cyan-dim);
  }
  .post-body :global(a:hover) { border-bottom-color: var(--accent-cyan); }

  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    padding: 0.1em 0.4em;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    color: var(--accent-cyan);
  }

  .post-body :global(pre) {
    font-family: var(--font-mono);
    background: var(--bg-card);
    color: var(--text-primary);
    padding: 1.5rem;
    border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--accent-cyan);
    overflow-x: auto;
    font-size: 0.86rem;
    line-height: 1.7;
    margin: 2rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .post-body :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.75rem;
    border-left: 3px solid var(--accent-cyan);
    background: var(--bg-card);
    font-style: italic;
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.55;
  }

  .post-body :global(ul), .post-body :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.6rem;
  }

  /* Footer */
  .post-footer {
    margin-top: 5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .pf-rule {
    width: 40px;
    height: 2px;
    background: var(--accent-cyan);
    margin-bottom: 2rem;
  }

  .pf-meta {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .pf-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.35rem;
  }

  .pf-value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--text-primary);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    border: none;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--accent-cyan); }
</style>
