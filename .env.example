# ═══════════════════════════════════════════════════════════════════════════════
# Agent Trust Network — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before starting the broker.
# Variables marked [PRODUCTION] should be changed from defaults in production.
#

# ─── Security ────────────────────────────────────────────────────────────────

# [REQUIRED] [PRODUCTION] Admin secret for dashboard login and API admin operations.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=change-me-in-production

# [PRODUCTION] Separate HMAC key for dashboard cookies. Auto-generated if empty.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SIGNING_KEY=

# [PRODUCTION] Comma-separated list of allowed CORS origins.
# Use specific origins in production, never "*".
ALLOWED_ORIGINS=*

# ─── Database ────────────────────────────────────────────────────────────────

# [PRODUCTION] PostgreSQL connection string. SQLite is for dev/test only.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://atn:atn@postgres:5432/agent_trust

# ─── Identity ────────────────────────────────────────────────────────────────

# SPIFFE trust domain for agent identities.
# Example: atn.yourcompany.com
TRUST_DOMAIN=atn.local

# [PRODUCTION] Require SPIFFE SAN URI in agent certificates.
REQUIRE_SPIFFE_SAN=false

# ─── Broker PKI ──────────────────────────────────────────────────────────────

# Path to broker CA key and certificate (inside the container).
BROKER_CA_KEY_PATH=/app/certs/broker-ca-key.pem
BROKER_CA_CERT_PATH=/app/certs/broker-ca.pem

# [PRODUCTION] Public URL of the broker (for DPoP HTU validation behind reverse proxy).
# Example: https://broker.yourcompany.com
BROKER_PUBLIC_URL=https://localhost:8443

# ─── KMS (Key Management) ───────────────────────────────────────────────────

# "local" = reads keys from disk (dev/test only)
# "vault" = HashiCorp Vault KV v2 (recommended for production)
KMS_BACKEND=local

# Vault settings (only when KMS_BACKEND=vault)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token
VAULT_SECRET_PATH=secret/data/broker
# VAULT_ALLOW_HTTP=true            # Dev only — remove in production (Vault must use HTTPS)

# ─── Redis ───────────────────────────────────────────────────────────────────

# Redis connection for DPoP JTI store, rate limiting, and WebSocket pub/sub.
# Empty = all components fall back to in-memory (single-worker only).
REDIS_URL=redis://redis:6379

# ─── Policy Engine ───────────────────────────────────────────────────────────

# "webhook" = per-org PDP webhooks (default)
# "opa"     = Open Policy Agent (enterprise)
POLICY_BACKEND=webhook

# OPA URL (only when POLICY_BACKEND=opa)
# OPA_URL=http://opa:8181

# ─── Observability ───────────────────────────────────────────────────────────

# OpenTelemetry — traces and metrics via OTLP/gRPC
OTEL_ENABLED=true
OTEL_SERVICE_NAME=agent-trust-broker
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Logging format — "text" (human-readable) or "json" (SIEM-ready)
LOG_FORMAT=text

# ─── OIDC (optional) ────────────────────────────────────────────────────────

# Network admin OIDC login (admin_secret remains as fallback)
# ADMIN_OIDC_ISSUER_URL=https://accounts.google.com
# ADMIN_OIDC_CLIENT_ID=
# ADMIN_OIDC_CLIENT_SECRET=

# ─── Runtime ─────────────────────────────────────────────────────────────────

BROKER_HOST=0.0.0.0
BROKER_PORT=8000
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Agents (used by agent scripts, not the broker) ─────────────────────────

# Anthropic API key for LLM-powered agents
# ANTHROPIC_API_KEY=sk-ant-...
