# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_SESSION_TOKEN_EXPIRE_MINUTES=60

# Broker
BROKER_HOST=0.0.0.0
BROKER_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./agent_trust.db

# Anthropic (usata dagli agent client in agents/)
ANTHROPIC_API_KEY=sk-ant-...

# Agent system prompt — set in per-agent .env, not here
# ORG_DISPLAY_NAME=MyOrg          # org name used in the default prompt template
# ORDER_ITEM=zinc-plated M8 bolts # product name for the initiator RFQ
# ORDER_QUANTITY=1000             # quantity for the initiator RFQ
# AGENT_SYSTEM_PROMPT=            # full override (leave empty to use default template)

# KMS — key management backend
# local  → reads broker-ca-key.pem from disk (dev/test only)
# vault  → HashiCorp Vault KV v2 (recommended for production)
KMS_BACKEND=local
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_SECRET_PATH=secret/data/broker

# Security
REQUIRE_CERT_VALIDATION=false   # true in produzione
ALLOWED_ORIGINS=*

# SPIFFE
TRUST_DOMAIN=atn.local          # trust domain per i SPIFFE ID (es. atn.example.com in prod)
REQUIRE_SPIFFE_SAN=false        # true in produzione (richiede SAN URI nel certificato agente)
