# Agente KYC di Banca A — INITIATOR
# Avvia DOPO banca_b.env (il responder deve essere già in ascolto)

BROKER_URL=http://localhost:8000

AGENT_ID=banca-a::kyc-agent
ORG_ID=banca-a
DISPLAY_NAME=Agente KYC Banca A
AGENT_SECRET=secret-banca-a-demo
CAPABILITIES=kyc.read,kyc.write

AGENT_ROLE=initiator
TARGET_AGENT_ID=banca-b::kyc-agent
TARGET_ORG_ID=banca-b

# Cliente da verificare
CUSTOMER_ID=CUST-001

POLL_INTERVAL=2
MAX_TURNS=6
