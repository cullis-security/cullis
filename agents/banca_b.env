# Agente KYC di Banca B — RESPONDER
# Avvia PRIMA di banca_a.env (deve essere in ascolto quando A apre la sessione)

BROKER_URL=http://localhost:8000

AGENT_ID=banca-b::kyc-agent
ORG_ID=banca-b
DISPLAY_NAME=Agente KYC Banca B
AGENT_SECRET=secret-banca-b-demo
CAPABILITIES=kyc.read

AGENT_ROLE=responder

POLL_INTERVAL=2
MAX_TURNS=6
