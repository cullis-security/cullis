# Buyer agent (purchaser) — INITIATOR
# Start AFTER manufacturer.env (the responder must already be listening)

BROKER_URL=http://localhost:8000

AGENT_ID=buyer::procurement-agent
ORG_ID=buyer
DISPLAY_NAME=Buyer Procurement Agent
AGENT_CERT_PATH=certs/buyer/buyer__procurement-agent.pem
AGENT_KEY_PATH=certs/buyer/buyer__procurement-agent-key.pem
ORG_SECRET=org-secret-buyer-demo
CAPABILITIES=order.read,order.write

AGENT_ROLE=initiator
# Hardcode a specific target, OR leave commented to use automatic discovery:
TARGET_AGENT_ID=manufacturer::sales-agent
TARGET_ORG_ID=manufacturer
# TARGET_AGENT_ID=
# TARGET_ORG_ID=

# Order to place
ORDER_ID=ORD-2026-001

POLL_INTERVAL=2
MAX_TURNS=8
