# Manufacturer agent (producer) — RESPONDER
# Start BEFORE buyer.env (must be listening when the buyer opens the session)

BROKER_URL=http://localhost:8000

AGENT_ID=manufacturer::sales-agent
ORG_ID=manufacturer
DISPLAY_NAME=Manufacturer Sales Agent
AGENT_CERT_PATH=certs/manufacturer/manufacturer__sales-agent.pem
AGENT_KEY_PATH=certs/manufacturer/manufacturer__sales-agent-key.pem
ORG_SECRET=org-secret-manufacturer-demo
CAPABILITIES=order.read,order.write

AGENT_ROLE=responder

POLL_INTERVAL=2
# Max turns per single session (not per lifetime — responder resets after each session)
MAX_TURNS=20
